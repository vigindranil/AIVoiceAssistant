{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "fluid": true,
  "rewrites": [
    { "source": "/api/diagnostics", "destination": "/api/diagnostics" },
    { "source": "/api/stream", "destination": "/api/stream" },
    { "source": "/(.*)", "destination": "/api" }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 300
    },
    "api/stream.js": {
      "maxDuration": 300
    }
  }
}
