PORT=3000
KIOSK_ID=KIOSK-DERM-01
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/google-cloud-key.json
# For Vercel, paste the complete service-account JSON (or its base64 value) instead of using a local path.
GOOGLE_CLOUD_CREDENTIALS_JSON=
SESSION_STORAGE_DIR=
# Generate with `openssl rand -hex 32`; required for portable Vercel visit sessions.
SESSION_SIGNING_SECRET=
INTAKE_LANGUAGE_CODE=en-IN
INTAKE_SPEECH_MODEL=latest_short

# Select exactly one realtime speech-to-text provider: google or openai
STT_PROVIDER=google
OPENAI_REALTIME_STT_MODEL=gpt-realtime-whisper
OPENAI_REALTIME_SESSION_MODEL=gpt-realtime-mini
MIN_ANSWER_CONFIDENCE=0.55

# Context-aware answer correction (optional; deterministic fallback is built in)
OPENAI_API_KEY=
LLM_MODEL=gpt-4.1-mini
LLM_API_URL=https://api.openai.com/v1/chat/completions
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=marin
OPENAI_TTS_SPEED=1.08

# Urgent alert webhook (recommended for clinical deployment)
FRONT_DESK_ALERT_URL=
FRONT_DESK_ALERT_TOKEN=
